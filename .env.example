PORT=3000
APPCHAT_PUBLIC_URL=http://127.0.0.1:3000
APPCHAT_DEFAULT_MODEL=appnz/auto-fast

# app.nz gateway and account APIs.
APPNZ_API_BASE=https://app.nz
APPNZ_API_KEY=pk_live_or_pk_test_from_appnz

# Optional: trusted first-party credit charge API.
APPNZ_APP_CLIENT_ID=appchat
APPNZ_APP_CLIENT_SECRET=
APPCHAT_ACTION_CREDITS=0

# Injected automatically by app.nz when the Postgres addon is enabled.
DATABASE_URL=postgres://user:pass@host:5432/appchat

# Solana prepaid credit demo.
SOLANA_RECEIVER_ADDRESS=
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CREDITS_PER_SOL=100000
SOLANA_ALLOW_DEV_CONFIRM=false
